{
    "name": "@diia-inhouse/crypto",
    "version": "1.20.3",
    "description": "Tools for encryption and auth",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-crypto",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "semantic-release": "semantic-release",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint --fix . && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "tsc --project tests/tsconfig.json --noEmit && vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "@types/jsonwebtoken": "9.0.10",
        "jsonwebtoken": "9.0.3",
        "node-jose": "2.2.0"
    },
    "peerDependencies": {
        "@diia-inhouse/errors": ">=1.0.0",
        "@diia-inhouse/types": ">=2.8.1",
        "@diia-inhouse/utils": ">=2.1.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/diia-logger": "3.19.1",
        "@diia-inhouse/errors": "1.18.10",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/test": "7.3.11",
        "@diia-inhouse/types": "11.7.0",
        "@diia-inhouse/utils": "5.3.8",
        "@diia-inhouse/validators": "1.28.15",
        "@types/node": "25.3.3",
        "@types/node-jose": "1.1.13",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "glob": "11.1.0",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "rimraf": "6.1.3",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
